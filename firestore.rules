rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function canUserCancelBooking() {
      return isSignedIn()
        && resource.data.userId == request.auth.uid
        && (
          (resource.data.cancellationDeadline is timestamp && request.time < resource.data.cancellationDeadline)
          || (
            !(resource.data.cancellationDeadline is timestamp)
            && resource.data.createdAt is timestamp
            && request.time < resource.data.createdAt + duration.value(24, 'h')
          )
        );
    }

    match /admins/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.bookings is list;
      allow update: if (isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.bookings is list)
        || isAdmin();
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin()
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.time is string
        && request.resource.data.date is timestamp
        && request.resource.data.capacity is int
        && request.resource.data.capacity > 0
        && request.resource.data.bookingCount is int
        && request.resource.data.bookingCount == 0;
      allow update: if (
          isAdmin()
          && request.resource.data.title is string
          && request.resource.data.description is string
          && request.resource.data.time is string
          && request.resource.data.date is timestamp
          && request.resource.data.capacity is int
          && request.resource.data.capacity >= resource.data.bookingCount
          && request.resource.data.bookingCount is int
          && request.resource.data.bookingCount >= 0
        )
        || (
          isSignedIn()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["bookingCount", "updatedAt"])
          && request.resource.data.bookingCount is int
          && request.resource.data.bookingCount >= 0
          && request.resource.data.bookingCount <= resource.data.capacity
          && (
            request.resource.data.bookingCount == resource.data.bookingCount + 1
            || request.resource.data.bookingCount == resource.data.bookingCount - 1
          )
        );
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email
        && request.resource.data.eventId is string
        && request.resource.data.ticketNumber is string
        && request.resource.data.qrCodeUrl is string
        && request.resource.data.status == "confirmed"
        && request.resource.data.checkedIn == false
        && request.resource.data.checkedInAt == null
        && request.resource.data.emailStatus is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.cancellationDeadline is timestamp
        && request.resource.data.cancellationDeadline > request.resource.data.createdAt
        && exists(/databases/$(database)/documents/events/$(request.resource.data.eventId));
      allow update: if isAdmin();
      allow delete: if isAdmin() || canUserCancelBooking();
    }

    match /appConfig/public {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
